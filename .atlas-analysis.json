  "keyFeatures": [
    "Shopping list management with per-product category and supermarket assignment",
    "Alphabetical (A-Z) and category-grouped product browsing views",
    "Shopping cart view with supermarket filtering and purchased-item tracking",
    "20 color-coded, renameable product categories",
    "Multiple supermarket support with drag-and-drop ordering and visibility control",
    "Progressive Web App (PWA) with offline support and service worker caching",
    "Cloud sync via REST API with JWT-based authentication",
    "FingerprintJS device identification for secure multi-device login",
    "Import/export configuration as JSON files",
    "Responsive design built with Bootstrap 5 and Vue 3"
  ],
  "publicApiSurface": [
    "myStore() — central Pinia-like reactive store composable",
    "useAuth() — login, register, logout composable",
    "useSync() — syncWithServer(), isSyncing, syncStatus",
    "useFingerprint() — device fingerprint identification",
    "useDraggable() — drag-and-drop ordering for supermarkets",
    "useMyInputModal() — reusable text input modal",
    "useMyProductEditModal() — product edit modal composable",
    "useProductFilter() — product list filtering logic",
    "localStorageService — getItem/setItem/getSubItem/setSubItem/importData/exportData/migrateOldData",
    "apiService — login(), register(), syncData(), getAll(), newProducto(), updateProducto(), deleteProducto()",
    "POST /login — authenticate user",
    "POST /register — register new user",
    "POST /syncData — sync local data with server",
    "GET /getAll — fetch all user data from server",
    "POST /newProducto — create product on server",
    "POST /updateProducto — update product on server",
    "POST /deleteProducto — delete product from server"
  ]
}
